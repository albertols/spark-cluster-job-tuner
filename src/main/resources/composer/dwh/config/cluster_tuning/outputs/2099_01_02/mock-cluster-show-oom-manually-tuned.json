{
  "clusterConf": {
    "mock-cluster-show-oom": {
      "num_workers": 5,
      "master_machine_type": "n2d-standard-48",
      "worker_machine_type": "n2d-standard-48",
      "autoscaling_policy": "medium-workload-autoscaling",
      "tuner_version": "2099_02_01",
      "total_no_of_jobs": 2,
      "cluster_max_total_memory_gb": 960,
      "cluster_max_total_cores": 240,
      "accumulated_max_total_memory_per_jobs_gb": 128,
      "boostedMemoryHeapJobCount": 1,
      "boostedMemoryHeapJobList": [
        "_DQ3_OOM_RECURRING.json"
      ]
    }
  },
  "recipeSparkConf": {
    "_DQ3_OOM_RECURRING.json": {
      "parallelizationFactor": 5,
      "appliedMemoryHeapBoostFactor": 1.5,
      "sparkOptsMap": {
        "spark.serializer": "org.apache.spark.serializer.KryoSerializer",
        "spark.closure.serializer": "org.apache.spark.serializer.KryoSerializer",
        "spark.executor.instances": "12",
        "spark.executor.cores": "4",
        "spark.executor.memory": "12g"
      },
      "total_executor_minimum_allocated_memory_gb": 144,
      "total_executor_maximum_allocated_memory_gb": 144
    },
    "_DQ3_OOM_COMPANION.json": {
      "parallelizationFactor": 5,
      "sparkOptsMap": {
        "spark.serializer": "org.apache.spark.serializer.KryoSerializer",
        "spark.closure.serializer": "org.apache.spark.serializer.KryoSerializer",
        "spark.executor.instances": "4",
        "spark.executor.cores": "4",
        "spark.executor.memory": "8g"
      },
      "total_executor_minimum_allocated_memory_gb": 32,
      "total_executor_maximum_allocated_memory_gb": 32
    }
  }
